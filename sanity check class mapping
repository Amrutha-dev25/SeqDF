"""
Quick sanity check for the new multi_hot <-> class_idx mapping, before trusting
it in a real training run. Run from seqdf/ folder:
    python sanity_check_class_mapping.py
"""
import sys, os
sys.path.append(os.path.dirname(os.path.abspath(__file__)))
import torch
from models.fusion.set_detection_head import ALL_SETS, NUM_CLASSES, multi_hot_to_class_idx, class_idx_to_multi_hot

print("ALL_SETS (index order: 0=DF, 1=F2F, 2=FSh, 3=FS, 4=NT):")
for i, combo in enumerate(ALL_SETS):
    names = ["DF", "F2F", "FSh", "FS", "NT"]
    print(f"  class {i}: {[names[m] for m in combo]}")

assert len(ALL_SETS) == 10, "Expected 10 classes"

mh = class_idx_to_multi_hot(torch.arange(10))
back = multi_hot_to_class_idx(mh)
assert torch.equal(back, torch.arange(10)), f"Round-trip FAILED: {back}"
assert torch.all(mh.sum(dim=1) == 3), "Not every class has exactly 3 positive methods"

# also test against a real example: DF+F2F+FSh present, FS+NT absent
example = torch.tensor([[1., 1., 1., 0., 0.]])
idx = multi_hot_to_class_idx(example)
print(f"\nExample [DF,F2F,FSh present] -> class index {idx.item()}")
recovered = class_idx_to_multi_hot(idx)
assert torch.equal(recovered, example), "Example round-trip failed"

print("\nAll sanity checks PASSED.")